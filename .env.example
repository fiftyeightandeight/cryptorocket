# Hyperliquid wallet (main or API wallet)
HYPERLIQUID_WALLET_ADDRESS=0xYourAddress
HYPERLIQUID_PRIVATE_KEY=0xYourPrivateKey

# Use API wallet for trading (recommended: can trade but cannot withdraw)
# HYPERLIQUID_API_WALLET_KEY=0xYourApiWalletKey

# Network: set to "true" for testnet, omit or "false" for mainnet
HYPERLIQUID_TESTNET=true

# Database path (default: crypto/data/crypto.duckdb)
# CRYPTO_DB_PATH=/path/to/crypto.duckdb
